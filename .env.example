# ============================================================
#  JP→VI Translation Pipeline — Environment Configuration
# ============================================================
#
# Copy this file to .env and customize for your environment.
#   cp .env.example .env
#
# All values below are the defaults used when not set.
# ============================================================

# ── Ollama Connection ──
OLLAMA_URL=http://localhost:11434
OLLAMA_TIMEOUT=1800

# ── Model ──
MODEL=gemma4:e4b

# ── Translation Parameters ──
TRANSLATION_TEMPERATURE=0.3
TRANSLATION_NUM_CTX=4096
TRANSLATION_MAX_RETRIES=3
MAX_CONCURRENT_BATCHES=2

# ── Extraction Parameters ──
MAX_INLINE_TAGS=8
MAX_SEGMENT_CHARS=400
BATCH_MAX_CHARS=3000
BATCH_MAX_SEGMENTS=5

# ── Paths ──
# For Docker deployment, use absolute paths like /data/output
# For local development, use relative paths like ./data/output
OUTPUT_DIR=./data/output
UPLOAD_DIR=./data/uploads
TEMP_DIR=./data/temp
DATABASE_URL=sqlite:///data/db/translations.db

# ── Workers ──
MAX_WORKERS=1
